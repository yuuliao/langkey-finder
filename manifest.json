{
  "manifest_version": 3,
  "name": "Langkey Finder",
  "version": "2.0",
  "description": "Find i18n langkey by displayed text (bns-web-member)",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["https://raw.githubusercontent.com/yuuliao/langkey-finder/*"],
  "action": {
    "default_title": "Find Langkey",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-finder": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle Langkey Finder"
    }
  }
}
